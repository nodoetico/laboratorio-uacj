# LabControl UACJ — Variables de Entorno
# Copia este archivo a .env y ajusta los valores

# Base de datos PostgreSQL (Railway proveerá esta URL automáticamente)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laboratorio_uacj"

# Secreto para firmar JWT — cambia esto en producción
JWT_SECRET="cambia-esto-por-un-secreto-seguro-en-produccion"

# Correo electrónico (SMTP) — opcional, para notificaciones al Dr. Torres
# Si no se configura, las notificaciones solo aparecen en la app
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
EMAIL_TO="jonatan.torres@uacj.mx"
